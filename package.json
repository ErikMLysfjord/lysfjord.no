{
	"name": "my-page",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"build": "vite build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --compiler-warnings unused-export-let:ignore",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch --compiler-warnings unused-export-let:ignore",
		"dev": "vite dev",
		"sst:dev": "sst dev",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"preview": "vite preview"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^3.3.1",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^3.1.2",
		"@types/eslint": "^8.56.12",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^9.1.2",
		"eslint-plugin-svelte": "^2.46.1",
		"globals": "^15.15.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"sst": "4.12.5",
		"svelte": "^4.2.20",
		"svelte-check": "^3.8.6",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.1",
		"vite": "^5.4.21"
	},
	"type": "module",
	"dependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/lora": "^5.2.8",
		"@sanity/client": "^7.20.0",
		"aws-rum-web": "^2.1.0",
		"svelte-kit-sst": "2.43.5"
	}
}
